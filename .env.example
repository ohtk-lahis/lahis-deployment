# LAHIS one-machine staging — environment template
# Copy to /opt/lahis/.env on the host and fill secrets.
# Do not commit real secrets.
#
# Contract: see CONTRACT.md
# Names must stay stable across AWS practice EC2 and bare metal.

# =============================================================================
# Deploy / host
# =============================================================================
ENV_NAME=staging
COMPOSE_PROJECT_NAME=lahis
DEPLOY_ROOT=/opt/lahis
DATA_ROOT=/data
# BACKUP_ROOT defaults to ${DATA_ROOT}/backups
# RETAIN_DAYS=14

# Image pins: prefer /opt/lahis/RELEASE digests (see RELEASE.example).
# Compose falls back to these if unset. Prefer digests over :latest for real deploys.
IMAGE_API=ghcr.io/onehealthtoolkit/ohtk-api:latest
IMAGE_MS=public.ecr.aws/g0x0v6d0/lahis-ms:latest

# =============================================================================
# Public hostnames (practice on ohtk.org)
# =============================================================================
DASHBOARD_HOST=lahis.ohtk.org
API_HOST=api.lahis.ohtk.org
# Wildcard DNS: *.api.lahis.ohtk.org → same machine
MINIO_PUBLIC_HOST=minio.lahis.ohtk.org
DEMO_TENANT_HOST=demo.api.lahis.ohtk.org

# =============================================================================
# Dashboard (lahis-ms — branded fork of ohtk-ms)
# Keys are lowercase: next.config.js / entrypoint replace use these names.
# =============================================================================
serverDomain=api.lahis.ohtk.org
tenantsApiEndpoint=https://api.lahis.ohtk.org/api/servers/

# =============================================================================
# Django core (ohtk-api)
# =============================================================================
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated; include leading-dot forms for tenant subdomains if required
DJANGO_ALLOWED_HOSTS=.api.lahis.ohtk.org,api.lahis.ohtk.org,lahis.ohtk.org
DASHBOARD_URL=https://lahis.ohtk.org

# Entrypoint (ohtk-api step 4+): do NOT migrate on every api start for shared staging.
# Use scripts/migrate.sh instead. Set True only for disposable empty-lab experiments.
RUN_MIGRATIONS=0
# SKIP_COLLECTSTATIC=0
# ASGI_HOST=0.0.0.0
# ASGI_PORT=8000

# Optional one-time bootstrap (docker entrypoint). Leave empty to skip.
# DJANGO_SUPERUSER_USERNAME=
# DJANGO_SUPERUSER_PASSWORD=
# DJANGO_SUPERUSER_EMAIL=

# =============================================================================
# Database (PostGIS)
# Inside compose, DB_HOST is the service name "db".
# =============================================================================
DB_HOST=db
DB_PORT=5432
DB_NAME=lahis
DB_USER=lahis
DB_PASSWORD=change-me-db-password

# Used by the db container (postgis image)
POSTGRES_DB=lahis
POSTGRES_USER=lahis
POSTGRES_PASSWORD=change-me-db-password

# =============================================================================
# Redis / Celery / Channels
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
# Staging/production: leave false so Redis-backed channels work
USE_INMEMORY_CHANNEL_LAYER=False
CELERY_TASK_ALWAYS_EAGER=False

# =============================================================================
# Object storage — MinIO (S3-compatible)
# USE_S3=True is the production-shaped path.
# AWS_S3_ENDPOINT_URL and related keys may need app settings wiring before first use.
# =============================================================================
USE_S3=True
AWS_ACCESS_KEY_ID=lahis-minio-access
AWS_SECRET_ACCESS_KEY=change-me-minio-app-secret
AWS_STORAGE_BUCKET_NAME=lahis-media
S3_MEDIA_BUCKET_NAME=lahis-media
AWS_S3_REGION_NAME=us-east-1

# Internal (compose network) — ohtk-api step 5+ settings
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_USE_SSL=False
AWS_S3_ADDRESSING_STYLE=path
# Public media host (proxy → minio)
# django-storages appends the object key after this value. Include the bucket
# for MinIO's path-style public endpoint: /lahis-media/media/<object>.
AWS_S3_CUSTOM_DOMAIN=minio.lahis.ohtk.org/lahis-media
# Public custom-domain URLs require the bucket's anonymous-download policy.
AWS_QUERYSTRING_AUTH=False
# AWS_DEFAULT_ACL=none

# MinIO server root credentials (minio container only; not the same as app keys ideally)
MINIO_ROOT_USER=lahis-minio-root
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_BUCKET=lahis-media
# Required when AWS_S3_CUSTOM_DOMAIN is configured for direct public media URLs.
MINIO_PUBLIC_READ=1

# Short lab only: set USE_S3=False and ignore MinIO if endpoint wiring is not ready.
# USE_S3=False

# =============================================================================
# Email (optional for first staging)
# =============================================================================
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
EMAIL_DOMAIN=lahis.ohtk.org

# =============================================================================
# Firebase / FCM
# Staging default: dry run (no real push). Leave FIREBASE_PRIVATE_KEY empty unless testing.
# =============================================================================
FCM_DRY_RUN=True
# FIREBASE_PRIVATE_KEY=   # base64-encoded service account private key if needed

# =============================================================================
# Proxy / TLS (used by future Caddyfile or deploy scripts)
# =============================================================================
# ACME email for Let's Encrypt (if using Caddy automatic HTTPS)
# ACME_EMAIL=ops@example.com
TLS_DOMAINS=lahis.ohtk.org,api.lahis.ohtk.org,minio.lahis.ohtk.org
# Note: wildcard certs need DNS challenge; often terminate tenant hosts with
# a certificate that covers *.api.lahis.ohtk.org via DNS-01 or a shared cert strategy.

# Caddy also stores certs under ${DATA_ROOT}/caddy (see compose.yml).
